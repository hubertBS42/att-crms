{
	"$schema": "https://v2-9-4.turborepo.dev/schema.json",
	"globalEnv": [
		"DATABASE_URL",
		"RECORDINGS_DIR",
		"SERVER_URL",
		"RECORDINGS_PATH",
		"BETTER_AUTH_SECRET",
		"BETTER_AUTH_URL",
		"SITE_MAILER_HOST",
		"SITE_MAILER_PORT",
		"SITE_MAILER_EMAIL",
		"SITE_MAILER_PASSWORD",
		"SEED_SUPERADMIN_EMAIL",
		"SEED_SUPERADMIN_PASSWORD",
		"SEED_SUPERADMIN_NAME"
	],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": [".next/**", "!.next/cache/**", "dist/**"],
			"cache": false
		},
		"@att-crms/watcher#build": {
			"dependsOn": ["@att-crms/web#build", "@att-crms/db#build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": ["dist/**"],
			"cache": false
		},
		"@att-crms/db#build": {
			"dependsOn": ["db:generate"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": ["dist/**"],
			"cache": false
		},
		"dev": {
			"dependsOn": ["@att-crms/db#build"],
			"cache": false,
			"persistent": true
		},
		"start": {
			"cache": false,
			"persistent": true
		},
		"lint": {
			"dependsOn": ["^lint"]
		},
		"db:generate": {
			"cache": false
		},
		"db:migrate": {
			"cache": false
		},
		"db:deploy": {
			"cache": false
		},
		"db:seed": {
			"cache": false,
			"dependsOn": ["db:generate"]
		},
		"db:studio": {
			"cache": false
		}
	}
}
