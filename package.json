{
	"name": "att-crms",
	"version": "1.0.0",
	"type": "module",
	"private": true,
	"scripts": {
		"dotenvx": "dotenvx",
		"dev": "dotenvx run -- turbo run dev",
		"build": "dotenvx run -- turbo run build",
		"start": "dotenvx run -- turbo run start",
		"lint": "turbo run lint",
		"db:generate": "dotenvx run -- turbo db:generate",
		"db:migrate": "dotenvx run -- turbo db:migrate",
		"db:deploy": "dotenvx run -- turbo db:deploy",
		"db:studio": "dotenvx run -- turbo db:studio",
		"db:seed": "dotenvx run -- turbo db:seed",
		"format": "prettier --write \"**/*.{ts,tsx,md}\"",
		"clean": "node scripts/clean.mjs"
	},
	"devDependencies": {
		"@dotenvx/dotenvx": "^1.60.0",
		"prettier": "^3.7.4",
		"turbo": "^2.9.4",
		"typescript": "5.9.2"
	},
	"packageManager": "pnpm@10.33.0",
	"engines": {
		"node": ">=18"
	}
}
